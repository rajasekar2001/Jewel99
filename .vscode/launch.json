{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter Web (Port 5000)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "chrome",
                "--web-port",
                "5000"
            ]
        },
        {
            "name": "Flutter Web Profile (Port 5000)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "chrome",
                "--web-port",
                "5000",
                "--profile"
            ]
        },
        {
            "name": "Flutter Web Release (Port 5000)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "args": [
                "-d",
                "chrome",
                "--web-port",
                "5000",
                "--release"
            ]
        }
    ]
}